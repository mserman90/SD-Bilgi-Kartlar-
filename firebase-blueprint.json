{
  "entities": {
    "Deck": {
      "title": "Deck",
      "description": "The main flashcards deck.",
      "type": "object",
      "properties": {
        "cards": {
          "type": "array"
        }
      },
      "required": ["cards"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and error reports.",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "userEmail": { "type": "string", "nullable": true },
        "userId": { "type": "string", "nullable": true }
      },
      "required": ["message", "type", "createdAt"]
    }
  },
  "firestore": {
    "/artifacts/{appId}/public/data/flashcards/main-deck": {
      "schema": {
        "$ref": "Deck"
      },
      "description": "Stores the flashcard deck"
    },
    "/artifacts/{appId}/feedback/{feedbackId}": {
      "schema": {
        "$ref": "Feedback"
      },
      "description": "Stores user feedback"
    }
  }
}
